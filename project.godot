; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GoneFishingSideScroll"
run/main_scene="uid://dnhmox84c11o8"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.18039216, 0.13333334, 0.18431373, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

OptionsManager="*uid://bpxbcyw03chrf"
SceneTransition="*uid://bkswihgy15q0b"
Debug="*uid://b8blnw84wgjho"
AudioManager="*uid://cguqk36yyswqc"
DialogueManager="*uid://c3rodes2l3gxb"
SignalManager="*uid://cp4f0ph1t108v"
GameManager="*uid://d25cud3bk0ynv"

[dialogue_manager]

runtime/balloon_path="res://scenes/dialogue/balloon.tscn"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg")

